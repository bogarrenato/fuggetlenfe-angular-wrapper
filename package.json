{
  "name": "@fuggetlenfe/angular-wrapper",
  "version": "0.2.0",
  "description": "Angular standalone wrapper for @fuggetlenfe/components.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bogarrenato/fuggetlenfe-angular-wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/bogarrenato/fuggetlenfe-angular-wrapper/issues"
  },
  "homepage": "https://bogarrenato.github.io/fuggetlenfe-angular-wrapper/latest/",
  "scripts": {
    "build": "ngc -p tsconfig.lib.json",
    "build:demo": "npm run build --prefix demo",
    "build:docs-site": "node scripts/build-docs-site.mjs",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@fuggetlenfe/components": "^0.2.0"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "typescript": "~5.9.3"
  }
}
